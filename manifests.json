{
  "format": "gomasterforge-manifests",
  "version": 1,
  "profile": {
    "active": "gm-main",
    "timezone": "UTC"
  },
  "mods": {
    "enabled": [
      "core@1.0.0",
      "core-dnd35@1.0.0"
    ],
    "export_profile": "dnd35-weekly"
  },
  "settings": {
